<Application x:Class="NexusProgrammer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NexusProgrammer"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F0F0F0"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#EFEFEF"/>
        <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="#E8E8E8"/>
        <SolidColorBrush x:Key="ToolbarButtonBackgroundBrush" Color="#E8E8E8"/>
        <SolidColorBrush x:Key="ToolbarButtonBorderBrush" Color="#E8E8E8"/>
        <SolidColorBrush x:Key="SurfaceBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SubtleBackgroundBrush" Color="#F6F6F6"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F7F7F7"/>
        <SolidColorBrush x:Key="ReadOnlyBackgroundBrush" Color="#F7F7F7"/>
        <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#E9F3FF"/>
        <SolidColorBrush x:Key="PressedBackgroundBrush" Color="#DDEEFF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0067C0"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#E5F1FB"/>
        <SolidColorBrush x:Key="AlternateRowBackgroundBrush" Color="#FBFBFB"/>
        <SolidColorBrush x:Key="TextBrush" Color="#000000"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#333333"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#B8B8B8"/>
        <SolidColorBrush x:Key="GridLineBrush" Color="#D9D9D9"/>
        <SolidColorBrush x:Key="LightGridLineBrush" Color="#F1F1F1"/>
        <SolidColorBrush x:Key="AddressBackgroundBrush" Color="#A8A8A8"/>
        <SolidColorBrush x:Key="AddressForegroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SplitterBrush" Color="#D8D8D8"/>
        <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="#DDEEFF"/>
        <SolidColorBrush x:Key="SelectionForegroundBrush" Color="#000000"/>
        <SolidColorBrush x:Key="ProgressTrackBrush" Color="#E5E5E5"/>
        <SolidColorBrush x:Key="StopBackgroundBrush" Color="#FFF0F0"/>
        <SolidColorBrush x:Key="StopForegroundBrush" Color="#B00000"/>
    </Application.Resources>
</Application>
